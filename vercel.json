{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "trouv.co.uk" }],
      "destination": "https://www.trouv.co.uk/:path*",
      "permanent": true
    }
  ]
}
