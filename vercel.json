{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "trouvchauffeurs.co.uk" }],
      "destination": "https://www.trouvchauffeurs.co.uk/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/page-sitemap.xml",
      "destination": "/sitemap.xml"
    }
  ]
}
