# Vercel: Project → Settings → Environment Variables (all three required for the contact form).
#
# 1) Create https://resend.com account, verify DNS for trouv.co.uk, and create an API key.
# 2) Use a "from" address on your verified domain (example below).
#
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO_EMAIL=info@trouv.co.uk
CONTACT_FROM_EMAIL=Trouv Website <website@trouv.co.uk>
GOOGLE_MAPS_API_KEY=your_google_maps_key_here